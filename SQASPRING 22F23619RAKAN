#include <iostream>
using namespace std;

int main() {
    int choice;
    int accountBalance = 150; // Example profile data
    bool isPremium = false;

    cout << "--- Account and Profile Menu ---" << endl;
    cout << "1. View Profile Type\n2. Upgrade Account\n";
    cout << "Enter your choice (1 or 2): ";
    cin >> choice;

    // Node 1: Entry into the switch block
    switch (choice) {
        case 1: 
            // Node 2: Check premium status
            if (isPremium) {
                cout << "Profile Status: Premium Member" << endl; // Node 3
            } else {
                cout << "Profile Status: Standard Member" << endl; // Node 4
            }
            break; // Node 5: Break out to end

        case 2:
            // Node 6: Check upgrade eligibility based on balance
            if (accountBalance >= 100) {
                isPremium = true;
                cout << "Upgrade successful! Welcome to Premium." << endl; // Node 7
            } else {
                cout << "Upgrade failed. Insufficient balance." << endl; // Node 8
            }
            break; // Node 9: Break out to end

        default:
            cout << "Invalid choice selected." << endl; // Node 10
            break;
    }

    // Node 11: End of program
    cout << "Thank you for using Profile Management." << endl; 
    return 0;
}
