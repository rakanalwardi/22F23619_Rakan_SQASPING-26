#include <iostream>
using namespace std;

int main() {
    int choice;
    int accountBalance = 150;
    bool isPremium = false;

    cout << "--- Account and Profile Menu ---" << endl;
    cout << "1. View Profile Type\n2. Upgrade Account\n";
    cout << "Enter your choice (1 or 2): ";
    cin >> choice;

    switch (choice) {
        case 1:
            if (isPremium) {
                cout << "Profile Status: Premium Member" << endl;
            } else {
                cout << "Profile Status: Standard Member" << endl;
            }
            break;

        case 2:
            if (accountBalance >= 100) {
                isPremium = true;
                cout << "Upgrade successful! Welcome to Premium." << endl;
            } else {
                cout << "Upgrade failed. Insufficient balance." << endl;
            }
            break;

        default:
            cout << "Invalid choice selected." << endl;
            break;
    }

    cout << "Thank you for using Profile Management." << endl;
    return 0;
}
